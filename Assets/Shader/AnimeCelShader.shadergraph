        {
            "m_Id": "e2bdd8bb3f494b53ad2d3d6f4cd2b5e7"
        },
        {
            "m_Id": "a4a8c59038c94157ab5e58128c1b8976"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GetMainLightData",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// En los settings del nodo: Inputs (WorldPos), Outputs (Direction, Attenuation)\r\n#if defined(SHADERGRAPH_PREVIEW)\r\n    Direction = half3(0.5, 0.5, 0);\r\n    Attenuation = 1;\r\n#else\r\n    // ESTO ES LO IMPORTANTE:\r\n    float4 shadowCoord = TransformWorldToShadowCoord(WorldPos); \r\n    Light light = GetMainLight(shadowCoord);\r\n    Direction = light.direction;\r\n    Attenuation = light.shadowAttenuation; // Aquí le pasas la sombra real\r\n#endif"
}

